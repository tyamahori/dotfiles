#!/bin/bash
set -euo pipefail

# Global Python is provided by uv. uv itself is installed via scripts/devbox
# (devbox global add uv). In a fresh setup run this script's PATH doesn't yet
# include the devbox global profile, so pull it in before calling uv.
if ! command -v uv >/dev/null 2>&1 && command -v devbox >/dev/null 2>&1; then
	eval "$(devbox global shellenv)"
fi

if ! command -v uv >/dev/null 2>&1; then
	echo "uv not found. Run scripts/devbox first (devbox global add uv)." >&2
	exit 1
fi

# Install the latest available CPython and register it as the global
# python / python3. uv writes the shims to ~/.local/bin, which .zprofile puts
# ahead of other pythons (e.g. the nix one) on PATH.
# --preview-features silences the "experimental" notice on --default.
uv python install --default --preview-features python-install-default
