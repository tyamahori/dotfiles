#!/bin/bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
DOTFILES_DIR="${REPO_ROOT}/dotfiles"
GIT_DIR="${REPO_ROOT}/git"
AGENTS_DIR="${REPO_ROOT}/agents"
CLAUDE_DIR="${REPO_ROOT}/claude"

# dotfiles
for dotfile in "${DOTFILES_DIR}"/.??*; do
	if [[ $dotfile == "$DOTFILES_DIR/." || $dotfile == "$DOTFILES_DIR/.." ]]; then
		continue
	fi
	ln -fnsv "$dotfile" "$HOME"
done

# global gitignore
mkdir -p "$HOME/.config/git"
ln -snfv "${GIT_DIR}/ignore" "$HOME/.config/git/ignore"

# claude code global settings (machine-local overrides go to ~/.claude/settings.local.json, gitignored)
mkdir -p "$HOME/.claude"
ln -snfv "${CLAUDE_DIR}/settings.json" "$HOME/.claude/settings.json"

# personal skills, shared across LLM CLIs
for skill in "${AGENTS_DIR}/skills"/*/; do
	skill="${skill%/}"
	for skills_dir in "$HOME/.claude/skills" "$HOME/.codex/skills" "$HOME/.copilot/skills" "$HOME/.agents/skills"; do
		mkdir -p "$skills_dir"
		ln -snfv "$skill" "$skills_dir/$(basename "$skill")"
	done
done

# OpenSkills installs these into its universal directory. Point each CLI at
# that one copy so agents that scan both locations do not register duplicates.
shared_openskills=(
	agents-sdk
	cloudflare
	cloudflare-email-service
	cloudflare-one
	cloudflare-one-migrations
	durable-objects
	sandbox-sdk
	turnstile-spin
	web-perf
	workers-best-practices
	wrangler
)
skill_backup_dir=""
for skill_name in "${shared_openskills[@]}"; do
	skill="$HOME/.agents/skills/$skill_name"
	if [[ ! -d $skill ]]; then
		echo "Missing shared skill: $skill" >&2
		exit 1
	fi

	for skills_dir in "$HOME/.claude/skills" "$HOME/.codex/skills" "$HOME/.copilot/skills"; do
		mkdir -p "$skills_dir"
		target="$skills_dir/$skill_name"
		if [[ -e $target && ! -L $target ]]; then
			if ! diff -qr "$skill" "$target" >/dev/null; then
				echo "Refusing to replace divergent skill: $target" >&2
				exit 1
			fi
			if [[ -z $skill_backup_dir ]]; then
				mkdir -p "$HOME/.Trash"
				skill_backup_dir="$(mktemp -d "$HOME/.Trash/shared-openskills.XXXXXX")"
			fi
			cli_name="$(basename "${skills_dir%/skills}")"
			mv "$target" "$skill_backup_dir/$cli_name-$skill_name"
		fi
		ln -snfv "$skill" "$target"
	done
done

# global agent instructions, shared across LLM CLIs (Claude Code, Codex, Copilot)
for agent_target in \
	"$HOME/.claude/CLAUDE.md" \
	"$HOME/.codex/AGENTS.md" \
	"$HOME/.copilot/copilot-instructions.md"; do
	mkdir -p "$(dirname "$agent_target")"
	ln -snfv "${AGENTS_DIR}/global-instructions.md" "$agent_target"
done

# Codex turn-completion notifications
mkdir -p "$HOME/.local/bin"
ln -snfv "${REPO_ROOT}/scripts/codex-notify" "$HOME/.local/bin/codex-notify"

# ghostty config (macOS reads the Application Support path; XDG is not needed)
mkdir -p "$HOME/Library/Application Support/com.mitchellh.ghostty"
ln -snfv "${REPO_ROOT}/ghostty/config" "$HOME/Library/Application Support/com.mitchellh.ghostty/config"

# herdr config (session state and logs stay unmanaged in ~/.config/herdr)
mkdir -p "$HOME/.config/herdr"
ln -snfv "${REPO_ROOT}/herdr/config.toml" "$HOME/.config/herdr/config.toml"

# launchd agents: link, then (re)load so schedule edits take effect
mkdir -p "$HOME/Library/LaunchAgents"
for plist in "${REPO_ROOT}/launchd"/*.plist; do
	target="$HOME/Library/LaunchAgents/$(basename "$plist")"
	ln -snfv "$plist" "$target"
	launchctl bootout "gui/$(id -u)" "$target" 2>/dev/null || true
	launchctl bootstrap "gui/$(id -u)" "$target"
done
